# ===== voice-draw backend 环境变量 =====
# 复制为 .env 后填写。所有变量缺省时仍可启动：
# ASR 自动降级 mock 上游（前端可再降 WebSpeech）；LLM 解析不可用时仅规则层 + 调试面板。

# 服务端口
PORT=8787

# ---- ASR：火山引擎豆包流式语音识别 ----
# 新版控制台单密钥模式（推荐）
VOLC_API_KEY=
# 旧版控制台双密钥模式（与 VOLC_API_KEY 二选一）
VOLC_APP_KEY=
VOLC_ACCESS_KEY=
# 资源 ID：1.0 小时版 volc.bigasr.sauc.duration / 并发版 .concurrent；2.0 为 volc.seedasr.sauc.*
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# 双向流式优化版（官方推荐）；如需切换基础版改为 .../bigmodel
VOLC_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
# 二遍识别（更准但 final 稍慢，仅优化版支持；延迟埋点后实测定夺）
VOLC_ASR_ENABLE_NONSTREAM=false

# ---- LLM / TTS：七牛云 AI ----
QINIU_API_KEY=
# OpenAI 兼容推理服务地址与模型（缺省即可）
QINIU_LLM_BASE_URL=https://openai.qiniu.com/v1
QINIU_LLM_MODEL=deepseek-v3
QINIU_TTS_URL=

# ---- 无密钥演示 ----
# mock ASR 上游 stop 后返回的 final 文本
MOCK_ASR_FINAL=画一个圆

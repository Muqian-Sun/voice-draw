# ===== voice-draw backend 环境变量 =====
# 复制为 .env 后填写。所有变量缺省时仍可启动：
# ASR 自动降级 mock 上游（前端可再降 WebSpeech）；LLM（火山方舟）未配置时仅规则层 + 调试面板。

# 服务端口
PORT=8787

# ---- ASR：火山引擎豆包流式语音识别 ----
# 新版控制台单密钥模式（推荐）
VOLC_API_KEY=
# 旧版控制台双密钥模式（与 VOLC_API_KEY 二选一）
VOLC_APP_KEY=
VOLC_ACCESS_KEY=
# 资源 ID：1.0 小时版 volc.bigasr.sauc.duration / 并发版 .concurrent；2.0 为 volc.seedasr.sauc.*
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# 双向流式优化版（官方推荐）；如需切换基础版改为 .../bigmodel
VOLC_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
# 二遍识别（更准但 final 稍慢，仅优化版支持；延迟埋点后实测定夺）
VOLC_ASR_ENABLE_NONSTREAM=false

# ---- LLM：火山方舟 Coding Plan ----
# 方舟控制台「API Key 管理」创建；与上面 ASR 的 VOLC_API_KEY 不是同一套密钥
ARK_API_KEY=
# Coding Plan 可用模型：deepseek-v4-flash / doubao-seed-code 等
ARK_LLM_MODEL=deepseek-v4-flash
# OpenAI 兼容端点（缺省即可；/api/coding 为 Anthropic 协议，勿混用）
ARK_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# 视觉自检用多模态模型（缺省即可；doubao-seed-code 实测支持图像输入）
ARK_VISION_MODEL=doubao-seed-code

# ---- TTS：火山引擎豆包大模型语音合成 2.0 ----
# 语音技术控制台应用的 APPID 与 Access Token（X-Api-* 头鉴权，与 ASR 的 VOLC_API_KEY 不同套）
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=
# 音色（缺省灿灿）
VOLC_TTS_SPEAKER=zh_female_cancan_mars_bigtts

# ---- 无密钥演示 ----
# mock ASR 上游 stop 后返回的 final 文本
MOCK_ASR_FINAL=画一个圆

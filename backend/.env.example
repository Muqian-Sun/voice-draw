# ===== voice-draw backend 环境变量 =====
# 复制为 .env 后填写。所有变量缺省时仍可启动：
# 前端将自动降级（ASR→浏览器 WebSpeech；LLM 解析不可用，仅规则层 + 调试面板）。

# 服务端口
PORT=8787

# 七牛云 AI 服务密钥（https://portal.qiniu.com 获取）
QINIU_API_KEY=

# 七牛云服务地址（一般无需修改，留空使用代码内默认值；接入 PR 时固化默认地址）
QINIU_ASR_WS_URL=
QINIU_LLM_BASE_URL=
QINIU_TTS_URL=

# mock ASR 上游（无密钥模式）stop 后返回的 final 文本，用于无密钥全链路演示
MOCK_ASR_FINAL=画一个圆
